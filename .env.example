# ── Required ──
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
GITHUB_TOKEN=ghp_your-github-pat
GITHUB_OWNER=via-decide

# ── Feature flags ──
SIMBA_ALLOW_LIVE_PUSH=true
SIMBA_ALLOW_LIVE_PR=true

# ── Security ──
# Comma-separated Telegram chat IDs allowed to use the bot
# Get your chat ID by messaging @userinfobot on Telegram
# Leave empty or omit SIMBA_ENFORCE_ADMIN_ONLY to allow all users
SIMBA_ADMIN_CHAT_IDS=
SIMBA_ENFORCE_ADMIN_ONLY=false

# ── Tuning ──
ARTIFACTS_DIR=artifacts
GITHUB_REPO_SCAN_LIMIT=30
TELEGRAM_POLL_INTERVAL_MS=3000
SIMBA_TASK_TIMEOUT_MS=120000
SIMBA_MAX_TASK_HISTORY=50
